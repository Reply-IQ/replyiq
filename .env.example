# ── SUPABASE (get from supabase.com → Project → Settings → Data API) ─────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── ANTHROPIC (get from console.anthropic.com → API Keys) ────────────────────
# Used on Vercel server-side (ANTHROPIC_KEY) AND for local dev (VITE_ANTHROPIC_KEY)
VITE_ANTHROPIC_KEY=sk-ant-api03-your_key_here

# ── GOOGLE PLACES (get from console.cloud.google.com) ────────────────────────
# Server-side only — add to Vercel environment variables as GOOGLE_PLACES_KEY
# Not needed in .env — only set in Vercel dashboard
# GOOGLE_PLACES_KEY=AIza...

# ── RESEND (get from resend.com — free 100 emails/day) ───────────────────────
# Server-side only — add to Vercel environment variables as RESEND_API_KEY  
# Not needed in .env — only set in Vercel dashboard
# RESEND_API_KEY=re_...
